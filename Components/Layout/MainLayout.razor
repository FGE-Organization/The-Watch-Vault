@inherits LayoutComponentBase

<div class="page">
    <header class="top-navbar">
        <div class="navbar-inner">
            <a class="navbar-brand" href="">The Watch Vault</a>
            <input type="checkbox" id="nav-toggle" class="nav-toggle" title="Toggle navigation" />
            <label for="nav-toggle" class="nav-toggle-label">
                <span></span>
                <span></span>
                <span></span>
            </label>
            <nav class="navbar-links">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
                <NavLink class="nav-link" href="shop">Shop</NavLink>
                <NavLink class="nav-link" href="brands">Brands</NavLink>
                <NavLink class="nav-link" href="login">Login</NavLink>
            </nav>
        </div>
    </header>

    <main>
        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
