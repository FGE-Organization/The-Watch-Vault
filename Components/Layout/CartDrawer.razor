@using System.Security.Claims
@using The_Watch_Vault.Data
@using The_Watch_Vault.Models
@implements IDisposable
@inject ICartRepository CartRepository
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject CartUiState CartUiState

@if (CartUiState.IsOpen)
{
    <div class="cart-drawer-backdrop" @onclick="CloseDrawer"></div>
    <aside class="cart-drawer" aria-label="Shopping cart preview">
        <div class="cart-drawer-header">
            <div>
                <p class="cart-drawer-kicker">Cart Preview</p>
                <h2>Your Bag</h2>
            </div>
            <button type="button" class="cart-drawer-close" @onclick="CloseDrawer" aria-label="Close cart drawer">&times;</button>
        </div>

        @if (_isLoading)
        {
            <div class="cart-drawer-state">Loading your cart...</div>
        }
        else if (!_items.Any())
        {
            <div class="cart-drawer-empty">
                <h3>Your cart is empty.</h3>
                <p>Add a watch from the collection to get started.</p>
            </div>
        }
        else
        {
            <div class="cart-drawer-items">
                @foreach (var item in _items)
                {
                    <article class="cart-drawer-item">
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" />
                        }

                        <div class="cart-drawer-item-copy">
                            <p class="cart-drawer-brand">@item.Brand</p>
                            <h3>@item.Name</h3>
                            <p class="cart-drawer-price">$@item.UnitPrice.ToString("N0")</p>
                            <div class="cart-drawer-controls">
                                <button type="button" @onclick="() => ChangeQuantity(item, -1)">-</button>
                                <span>@item.Quantity</span>
                                <button type="button" @onclick="() => ChangeQuantity(item, 1)">+</button>
                            </div>
                        </div>

                        <button type="button" class="cart-drawer-remove" @onclick="() => RemoveItem(item)">Remove</button>
                    </article>
                }
            </div>

            <div class="cart-drawer-summary">
                <div>
                    <span>Subtotal</span>
                    <strong>$@CartTotal.ToString("N0")</strong>
                </div>

                <button type="button" class="hero-cta cart-drawer-checkout" @onclick="ContinueToCheckout">Continue to checkout</button>
            </div>
        }
    </aside>
}

@code {
    private List<CartItem> _items = new();
    private bool _isLoading = true;
    private string? _userId;

    private double CartTotal => _items.Sum(item => item.TotalPrice);

    protected override void OnInitialized()
    {
        CartUiState.Changed += OnCartStateChanged;
    }

    private async void OnCartStateChanged()
    {
        try
        {
            if (CartUiState.IsOpen)
            {
                await RefreshCartAsync();
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CartDrawer] Error in OnCartStateChanged: {ex.Message}");
        }
    }

    private async Task RefreshCartAsync()
    {
        _isLoading = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrWhiteSpace(_userId))
                {
                    _items = await CartRepository.GetCartAsync(_userId);
                    CartUiState.SetItemCount(_items.Sum(i => i.Quantity));
                    Console.WriteLine($"[CartDrawer] Loaded {_items.Count} item(s) for user {_userId}");
                }
                else
                {
                    _items = new();
                }
            }
            else
            {
                _items = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CartDrawer] RefreshCart error: {ex.Message}");
            _items = new();
        }

        _isLoading = false;
    }

    private async Task ChangeQuantity(CartItem item, int delta)
    {
        if (string.IsNullOrWhiteSpace(_userId) || string.IsNullOrWhiteSpace(item.Id))
            return;

        var newQty = item.Quantity + delta;
        if (newQty < 1) newQty = 1;

        await CartRepository.UpdateQuantityAsync(_userId, item.Id, newQty);
        await RefreshCartAsync();
        StateHasChanged();
    }

    private async Task RemoveItem(CartItem item)
    {
        if (string.IsNullOrWhiteSpace(_userId) || string.IsNullOrWhiteSpace(item.Id))
            return;

        await CartRepository.RemoveFromCartAsync(_userId, item.Id);
        await RefreshCartAsync();
        StateHasChanged();
    }

    private void ContinueToCheckout()
    {
        CartUiState.Close();
        NavManager.NavigateTo("/cart");
    }

    private void CloseDrawer()
    {
        CartUiState.Close();
    }

    public void Dispose()
    {
        CartUiState.Changed -= OnCartStateChanged;
    }
}