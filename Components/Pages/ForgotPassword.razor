@page "/forgot-password"

<PageTitle>Forgot Password — The Watch Vault</PageTitle>

<section class="recovery-section">
    <div class="recovery-backdrop"></div>
    <div class="recovery-container">
        <div class="recovery-card">
            <p class="recovery-tagline">Est. 2026 · Account Recovery</p>
            <h1 class="recovery-title">Forgot Password</h1>
            <p class="recovery-subtitle">Enter your email and we'll send a link to create a new password.</p>

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="recovery-alert recovery-alert-success">
                    @SuccessMessage
                </div>
            }

            <EditForm Model="model" OnValidSubmit="HandleRequest" class="recovery-form">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-group">
                    <label for="email">Email</label>
                    <InputText id="email"
                               @bind-Value="model.Email"
                               class="form-input"
                               placeholder="you@example.com"
                               autocomplete="email" />
                    <ValidationMessage For="@(() => model.Email)" />
                </div>

                <button type="submit" class="recovery-btn">Send Reset Link</button>
            </EditForm>

            <p class="recovery-footer">
                Remembered your password? <a href="/login" class="recovery-link">Sign in</a>
            </p>
        </div>
    </div>
</section>

@code {
    private ForgotPasswordModel model = new();
    private string? SuccessMessage { get; set; }

    private void HandleRequest()
    {
        SuccessMessage = "If an account exists for that email, we've sent a password reset link.";
    }

    private class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = "";
    }
}