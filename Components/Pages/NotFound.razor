@page "/404"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Page not found</PageTitle>

<section class="not-found">
    <h1>Page not found</h1>
    <p>Sorry, there is nothing at this address.</p>
    <a class="back-home" href="/">Go back home</a>
</section>

<style>
    .not-found {
        min-height: 60vh;
        display: grid;
        place-content: center;
        gap: 0.75rem;
        text-align: center;
        padding: 2rem;
    }

    .not-found h1 {
        margin: 0;
    }

    .not-found p {
        margin: 0;
        color: #b8b8c2;
    }

    .back-home {
        margin-top: 0.5rem;
        color: #c6a66b;
        text-decoration: none;
        font-weight: 600;
    }

    .back-home:hover {
        text-decoration: underline;
    }
</style>

