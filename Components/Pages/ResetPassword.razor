@page "/reset-password"
@page "/new-password"
@using Microsoft.AspNetCore.Components

<PageTitle>Set New Password — The Watch Vault</PageTitle>

<section class="recovery-section">
    <div class="recovery-backdrop"></div>
    <div class="recovery-container">
        <div class="recovery-card">
            <p class="recovery-tagline">Est. 2026 · Account Recovery</p>
            <h1 class="recovery-title">Create New Password</h1>
            <p class="recovery-subtitle">Enter the reset code from your email and choose a new password.</p>

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="recovery-alert recovery-alert-success">
                    @SuccessMessage
                    <a href="/login" class="recovery-link-inline">Sign in</a>
                </div>
            }

            <EditForm Model="model" OnValidSubmit="HandleReset" class="recovery-form">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-group">
                    <label for="code">Reset Code</label>
                    <InputText id="code"
                               @bind-Value="model.Code"
                               class="form-input"
                               placeholder="Enter the code from your email"
                               autocomplete="one-time-code" />
                    <ValidationMessage For="@(() => model.Code)" />
                </div>

                <div class="form-group">
                    <label for="password">New Password</label>
                    <InputText id="password"
                               type="password"
                               @bind-Value="model.Password"
                               class="form-input"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                    <ValidationMessage For="@(() => model.Password)" />
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm New Password</label>
                    <InputText id="confirmPassword"
                               type="password"
                               @bind-Value="model.ConfirmPassword"
                               class="form-input"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                    <ValidationMessage For="@(() => model.ConfirmPassword)" />
                </div>

                <button type="submit" class="recovery-btn">Update Password</button>
            </EditForm>

            <p class="recovery-footer">
                Need a new reset email? <a href="/forgot-password" class="recovery-link">Request another link</a>
            </p>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "code")]
    public string? Code { get; set; }

    private ResetPasswordModel model = new();
    private string? SuccessMessage { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Code))
        {
            model.Code = Code;
        }
    }

    private void HandleReset()
    {
        SuccessMessage = "Your password has been updated. You can now sign in with your new password.";
    }

    private class ResetPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Reset code is required")]
        public string Code { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm your password")]
        [System.ComponentModel.DataAnnotations.Compare("Password", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }
}