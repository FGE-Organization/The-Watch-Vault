@page "/shop"

<PageTitle>Shop — The Watch Vault</PageTitle>

<section class="shop-hero">
    <div class="shop-hero-backdrop"></div>
    <div class="shop-hero-content">
        <p class="shop-tagline">Curated Selection</p>
        <h1 class="shop-title">The Collection</h1>
        <p class="shop-subtitle">Discover our exclusive range of luxury timepieces gracefully mapped from the Vault.</p>
    </div>
</section>

<section class="shop-main">
    <div class="shop-container">
        
        <!-- Sidebar Filters -->
        <aside class="shop-filters">
            <div class="filter-box">
                <div class="filter-group">
                    <h3>Brands</h3>
                    <ul>
                        @foreach(var b in Brands) {
                            <li>
                                <label class="checkbox-label">
                                    <input type="checkbox" class="form-checkbox" />
                                    <span>@b.Name</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>
                
                <div class="filter-group">
                    <h3>Categories</h3>
                    <ul>
                        @foreach(var c in Categories) {
                            <li>
                                <label class="checkbox-label">
                                    <input type="checkbox" class="form-checkbox" />
                                    <span>@c.Name</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </aside>

        <!-- Main Grid -->
        <div class="shop-grid-area">
            <div class="shop-toolbar">
                <span>Showing @Watches.Count watches</span>
                <select class="form-input sort-select">
                    <option>Sort by: Featured</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                </select>
            </div>
            
            <div class="collections-grid">
                @foreach(var w in Watches) {
                    <div class="collection-card">
                        <div class="card-image-wrapper">
                            <img src="@w.ImageUrl" alt="@w.Name" loading="lazy" />
                        </div>
                        <div class="card-body">
                            <p class="watch-brand">@w.Brand</p>
                            <h3 class="watch-name">@w.Name</h3>
                            <p class="watch-price">$@w.Price.ToString("N0")</p>
                            <button class="add-to-cart-btn login-btn">Add to Cart</button>
                        </div>
                    </div>
                }
            </div>
        </div>
        
    </div>
</section>

