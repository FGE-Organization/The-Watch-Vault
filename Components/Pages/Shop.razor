@page "/shop"
@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@using System.Linq
@using System.Text.Json
@using System.Text.Json.Serialization
@using The_Watch_Vault.Models
@using The_Watch_Vault.Data
@inject IWatchRepository WatchRepository
@inject ICartRepository CartRepository
@inject AuthenticationStateProvider AuthStateProvider
@inject CartUiState CartUiState

<PageTitle>Shop — The Watch Vault</PageTitle>

<section class="shop-hero">
    <div class="shop-hero-backdrop"></div>
    <div class="shop-hero-content">
        <p class="shop-tagline">Curated Selection</p>
        <h1 class="shop-title">The Collection</h1>
        <p class="shop-subtitle">Discover our exclusive range of luxury timepieces gracefully mapped from the Vault.</p>
    </div>
</section>

<section class="shop-main">
    <div class="shop-container">
        @if (string.Equals(CheckoutStatus, "success", StringComparison.OrdinalIgnoreCase))
        {
            <div class="checkout-success-banner">
                <strong>Purchase complete.</strong>
                <span>Your order has been recorded and your cart has been cleared.</span>
            </div>
        }

        <div class="shop-filters">
            <div class="filter-box">
                <div class="filter-group">
                    <h3>Search</h3>
                    <input id="shop-search" type="search" class="form-input search-input" value="@SearchQuery" @oninput="OnSearchInput" placeholder="Search by name or brand..." autocomplete="off" />
                </div>
                <div class="filter-group">
                    <h3>Brands</h3>
                    <ul>
                        @foreach (var b in Brands)
                        {
                            <li>
                                <label class="checkbox-label">
                                    <input type="checkbox"
                                           class="form-checkbox"
                                           checked="@SelectedBrands.Contains(b.Name)"
                                           @onchange="@(e => OnBrandToggle(b.Name, e))" />
                                    <span>@b.Name</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>
                <div class="filter-group">
                    <h3>Sort</h3>
                    <select id="shop-sort" class="form-input sort-select" value="@CurrentSort" @onchange="OnSortChanged">
                        <option value="Featured">Sort by: Featured</option>
                        <option value="PriceAsc">Price: Low to High</option>
                        <option value="PriceDesc">Price: High to Low</option>
                    </select>
                </div>
                <button id="shop-reset" type="button" class="hero-cta" style="width: 100%;" @onclick="ResetFilters">Reset Filters</button>
            </div>
        </div>

        <!-- Main Grid -->
        <div class="shop-grid-area">
            <div class="shop-toolbar">
                <span id="shop-count">Showing @FilteredWatches.Count() @(FilteredWatches.Count() == 1 ? "watch" : "watches")</span>
            </div>

            @if (!string.IsNullOrEmpty(_toastMessage))
            {
                <div class="cart-toast @(_toastIsError ? "cart-toast-error" : "cart-toast-success")">
                    @_toastMessage
                </div>
            }
            
            @if (IsLoading)
            {
                <div class="shop-loading">
                    <div class="loading-spinner"></div>
                    <p>Loading the collection...</p>
                </div>
            }
            else if (!FilteredWatches.Any())
            {
                <div class="shop-empty-state" id="shop-empty">
                    <p>No watches match your filters.</p>
                </div>
            }
            else
            {
                <div class="collections-grid" id="shop-grid">
                    @foreach (var w in FilteredWatches)
                    {
                        <div class="collection-card">
                            <div class="card-image-wrapper">
                                <img src="@w.ImageUrl" alt="@w.Name" loading="lazy" />
                            </div>
                            <div class="card-body">
                                <p class="watch-brand">@w.Brand</p>
                                <h3 class="watch-name">@w.Name</h3>
                                <p class="watch-price">$@w.Price.ToString("N0")</p>
                                @if (w.InStock)
                                {
                                    <button type="button"
                                            class="add-to-cart-btn hero-cta"
                                            disabled="@_addingWatchId.Equals(w.Id)"
                                            @onclick="() => HandleAddToCart(w)">
                                        @if (_addingWatchId == w.Id)
                                        {
                                            <span>Adding...</span>
                                        }
                                        else
                                        {
                                            <span>Add to Cart</span>
                                        }
                                    </button>
                                }
                                else
                                {
                                    <button class="add-to-cart-btn hero-cta" disabled style="opacity: 0.5; cursor: not-allowed;">Out of Stock</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        
    </div>
</section>

<!-- Newsletter -->
<section class="newsletter-lux-section">
    <div class="newsletter-lux-wrapper">
        <div class="newsletter-lux-card">
            <div class="newsletter-lux-content">
                <p class="newsletter-lux-kicker">Stay Connected</p>
                <h2 class="newsletter-lux-title">Join Our Newsletter</h2>
                <p class="newsletter-lux-text">
                    Receive curated updates, featured arrivals, and exclusive highlights from The Watch Vault.
                </p>
            </div>

            <form class="newsletter-lux-form" onsubmit="return showNewsletterMessage(event)">
                <input type="email"
                       class="newsletter-lux-input"
                       placeholder="Enter your email"
                       required />
                <button type="submit" class="newsletter-lux-btn">Subscribe</button>
            </form>

            <p id="newsletterMessage" class="newsletter-lux-message">
                Email registered successfully.
            </p>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="site-footer" id="site-footer">
    <div class="footer-content">
        <div class="footer-brand">
            <h4>The Watch Vault</h4>
            <p>Your destination for luxury timepieces.</p>
        </div>
        <div class="footer-links">
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
            <a href="/login">Login</a>
            <a href="/signup">Create Account</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 The Watch Vault. All rights reserved.</p>
    </div>
</footer>

<script>
function showNewsletterMessage(event) {
    event.preventDefault();

    const message = document.getElementById('newsletterMessage');
    const input = document.querySelector('.newsletter-lux-input');

    if (!message || !input) {
        return false;
    }

    if (input.value.trim() === '') {
        return false;
    }

    message.classList.add('show');
    input.value = '';

    setTimeout(() => {
        message.classList.remove('show');
    }, 2500);

    return false;
}

</script>

@code {
    public record BrandItem(string Id, string Description, string LogoUrl, string Name);

    public List<BrandItem> Brands = new()
    {
        new BrandItem("1", "Swiss luxury watchmaker.", "", "Rolex"),
        new BrandItem("2", "Innovative Swiss luxury watches.", "", "Omega"),
        new BrandItem("3", "Unparalleled craftsmanship.", "", "Patek Philippe"),
        new BrandItem("4", "Redefining luxury.", "", "Audemars Piguet"),
        new BrandItem("5", "Master of shapes.", "", "Cartier")
    };

    public List<Watch> Watches { get; set; } = new();
    public bool IsLoading { get; set; } = true;

    // Toast state
    private string? _toastMessage;
    private bool _toastIsError;
    private string _addingWatchId = "";

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "q")]
    public string? SearchQuery { get; set; }

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "sort")]
    public string? CurrentSort { get; set; }

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "checkout")]
    public string? CheckoutStatus { get; set; }

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "brand")]
    public string[]? SelectedBrandNames { get; set; }

    public HashSet<string> SelectedBrands { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("[Shop] OnInitializedAsync — loading watches...");
        try
        {
            Watches = await WatchRepository.GetAllAsync();
            Console.WriteLine($"[Shop] Loaded {Watches.Count} watches.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Shop] Failed to load watches from DB: {ex.Message}");
            Watches = new();
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override void OnParametersSet()
    {
        SearchQuery = SearchQuery?.Trim() ?? string.Empty;
        CurrentSort = string.IsNullOrWhiteSpace(CurrentSort) ? "Featured" : CurrentSort;
        SelectedBrands = SelectedBrandNames is null
            ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            : SelectedBrandNames.Where(brand => !string.IsNullOrWhiteSpace(brand))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? string.Empty;
        SyncUrlFromFilters();
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        CurrentSort = e.Value?.ToString() ?? "Featured";
        SyncUrlFromFilters();
    }

    private void OnBrandToggle(string brandName, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool b && b;
        if (isChecked)
        {
            SelectedBrands.Add(brandName);
        }
        else
        {
            SelectedBrands.Remove(brandName);
        }

        SyncUrlFromFilters();
    }

    private void ResetFilters()
    {
        SearchQuery = string.Empty;
        CurrentSort = "Featured";
        SelectedBrands.Clear();
        SyncUrlFromFilters();
    }

    private void SyncUrlFromFilters()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            parts.Add($"q={Uri.EscapeDataString(SearchQuery.Trim())}");
        }

        if (!string.IsNullOrWhiteSpace(CurrentSort) && !string.Equals(CurrentSort, "Featured", StringComparison.Ordinal))
        {
            parts.Add($"sort={Uri.EscapeDataString(CurrentSort)}");
        }

        foreach (var b in SelectedBrands.OrderBy(x => x))
        {
            parts.Add($"brand={Uri.EscapeDataString(b)}");
        }

        if (!string.IsNullOrEmpty(CheckoutStatus))
        {
            parts.Add($"checkout={Uri.EscapeDataString(CheckoutStatus)}");
        }

        var query = parts.Count > 0 ? "?" + string.Join("&", parts) : string.Empty;
        NavigationManager.NavigateTo("/shop" + query, replace: true);
    }

    private async Task HandleAddToCart(Watch watch)
    {
        Console.WriteLine($"[Shop] HandleAddToCart clicked for: {watch.Name} (Id={watch.Id})");
        _toastMessage = null;
        _addingWatchId = watch.Id ?? "";

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            Console.WriteLine($"[Shop] Auth check: IsAuthenticated={user.Identity?.IsAuthenticated}");

            if (user.Identity is not { IsAuthenticated: true })
            {
                _toastMessage = "Please log in to add items to your cart.";
                _toastIsError = true;
                Console.WriteLine("[Shop] User not authenticated.");
                return;
            }

            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            Console.WriteLine($"[Shop] userId = {userId}");

            if (string.IsNullOrWhiteSpace(userId))
            {
                _toastMessage = "Could not identify your account. Try logging out and back in.";
                _toastIsError = true;
                Console.WriteLine("[Shop] userId was null/empty.");
                return;
            }

            var cartItem = new CartItem
            {
                WatchId = watch.Id ?? Guid.NewGuid().ToString(),
                Brand = watch.Brand,
                Name = watch.Name,
                ImageUrl = watch.ImageUrl,
                UnitPrice = watch.Price,
                Quantity = 1
            };

            Console.WriteLine("[Shop] Calling CartRepository.AddToCartAsync...");
            await CartRepository.AddToCartAsync(userId, cartItem);
            Console.WriteLine("[Shop] AddToCartAsync succeeded.");

            // Refresh item count
            var updatedCart = await CartRepository.GetCartAsync(userId);
            CartUiState.SetItemCount(updatedCart.Sum(ci => ci.Quantity));
            CartUiState.Open();

            _toastMessage = $"✓ {watch.Name} added to cart!";
            _toastIsError = false;
            Console.WriteLine($"[Shop] Cart now has {updatedCart.Count} item(s).");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Shop] EXCEPTION in HandleAddToCart: {ex}");
            _toastMessage = $"Error: {ex.Message}";
            _toastIsError = true;
        }
        finally
        {
            _addingWatchId = "";
        }
    }

    public IEnumerable<Watch> FilteredWatches
    {
        get
        {
            var query = Watches.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchQuery))
            {
                var lowerSearch = SearchQuery.ToLowerInvariant();
                query = query.Where(w =>
                    w.Name.ToLowerInvariant().Contains(lowerSearch) ||
                    w.Brand.ToLowerInvariant().Contains(lowerSearch) ||
                    w.Description.ToLowerInvariant().Contains(lowerSearch)
                );
            }

            if (SelectedBrands.Any())
            {
                query = query.Where(w => SelectedBrands.Contains(w.Brand));
            }

            return CurrentSort switch
            {
                "PriceAsc" => query.OrderBy(w => w.Price),
                "PriceDesc" => query.OrderByDescending(w => w.Price),
                _ => query
            };
        }
    }
}
