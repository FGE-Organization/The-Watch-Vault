@page "/shop"
@attribute [Microsoft.AspNetCore.Components.ExcludeFromInteractiveRouting]
@inject The_Watch_Vault.Services.FirestoreService FirestoreService
@using System.Linq
@using The_Watch_Vault.Services

<PageTitle>Shop — The Watch Vault</PageTitle>

<section class="shop-hero">
    <div class="shop-hero-backdrop"></div>
    <div class="shop-hero-content">
        <p class="shop-tagline">Curated Selection</p>
        <h1 class="shop-title">The Collection</h1>
        <p class="shop-subtitle">Discover our exclusive range of luxury timepieces gracefully mapped from the Vault.</p>
    </div>
</section>

<section class="shop-main">
    <div class="shop-container">
        <div class="shop-filters">
            <div class="filter-box">
                <div class="filter-group">
                    <h3>Search</h3>
                    <input id="shop-search" type="search" class="form-input search-input" value="@SearchQuery" placeholder="Search by name or brand..." autocomplete="off" />
                </div>
                <div class="filter-group">
                    <h3>Brands</h3>
                    <ul>
                        @foreach (var b in Brands)
                        {
                            <li>
                                <label class="checkbox-label">
                                    <input type="checkbox"
                                           class="form-checkbox"
                                           data-brand-filter="true"
                                           value="@b.Name"
                                           checked="@SelectedBrands.Contains(b.Name)" />
                                    <span>@b.Name</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>
                <div class="filter-group">
                    <h3>Sort</h3>
                    <select id="shop-sort" class="form-input sort-select">
                        <option value="Featured" selected="@(CurrentSort == "Featured")">Sort by: Featured</option>
                        <option value="PriceAsc" selected="@(CurrentSort == "PriceAsc")">Price: Low to High</option>
                        <option value="PriceDesc" selected="@(CurrentSort == "PriceDesc")">Price: High to Low</option>
                    </select>
                </div>
                <button id="shop-reset" type="button" class="hero-cta" style="width: 100%;">Reset Filters</button>
            </div>
        </div>

        <!-- Main Grid -->
        <div class="shop-grid-area">
            <div class="shop-toolbar">
                <span id="shop-count">Showing @FilteredWatches.Count() watches</span>
            </div>
            
            @if (IsLoading)
            {
                <div class="shop-loading">
                    <div class="loading-spinner"></div>
                    <p>Loading the collection...</p>
                </div>
            }
            else
            {
                <div class="shop-empty-state" id="shop-empty" hidden>
                    <p>No watches match your filters.</p>
                </div>

                <div class="collections-grid" id="shop-grid">
                    @{ var watchIndex = 0; }
                    @foreach (var w in FilteredWatches)
                    {
                        <div class="collection-card"
                             data-watch-card="true"
                             data-index="@watchIndex"
                             data-name="@w.Name"
                             data-brand="@w.Brand"
                             data-description="@w.Description"
                             data-price="@w.Price"
                             data-in-stock="@w.InStock.ToString().ToLowerInvariant()">
                            <div class="card-image-wrapper">
                                <img src="@w.ImageUrl" alt="@w.Name" loading="lazy" />
                            </div>
                            <div class="card-body">
                                <p class="watch-brand">@w.Brand</p>
                                <h3 class="watch-name">@w.Name</h3>
                                <p class="watch-price">$@w.Price.ToString("N0")</p>
                                @if (w.InStock)
                                {
                                    <button class="add-to-cart-btn hero-cta">Add to Cart</button>
                                }
                                else
                                {
                                    <button class="add-to-cart-btn hero-cta" disabled style="opacity: 0.5; cursor: not-allowed;">Out of Stock</button>
                                }
                            </div>
                        </div>
                        watchIndex++;
                    }
                </div>
            }
        </div>
        
    </div>
</section>

<!-- Newsletter -->
<section class="newsletter-lux-section">
    <div class="newsletter-lux-wrapper">
        <div class="newsletter-lux-card">
            <div class="newsletter-lux-content">
                <p class="newsletter-lux-kicker">Stay Connected</p>
                <h2 class="newsletter-lux-title">Join Our Newsletter</h2>
                <p class="newsletter-lux-text">
                    Receive curated updates, featured arrivals, and exclusive highlights from The Watch Vault.
                </p>
            </div>

            <form class="newsletter-lux-form" onsubmit="return showNewsletterMessage(event)">
                <input type="email"
                       class="newsletter-lux-input"
                       placeholder="Enter your email"
                       required />
                <button type="submit" class="newsletter-lux-btn">Subscribe</button>
            </form>

            <p id="newsletterMessage" class="newsletter-lux-message">
                Email registered successfully.
            </p>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="site-footer" id="site-footer">
    <div class="footer-content">
        <div class="footer-brand">
            <h4>The Watch Vault</h4>
            <p>Your destination for luxury timepieces.</p>
        </div>
        <div class="footer-links">
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
            <a href="/login">Login</a>
            <a href="/signup">Create Account</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 The Watch Vault. All rights reserved.</p>
    </div>
</footer>

<script>
(() => {
    const searchInput = document.getElementById('shop-search');
    const sortSelect = document.getElementById('shop-sort');
    const resetButton = document.getElementById('shop-reset');
    const countNode = document.getElementById('shop-count');
    const emptyState = document.getElementById('shop-empty');
    const grid = document.getElementById('shop-grid');

    if (!searchInput || !sortSelect || !grid) {
        return;
    }

    const brandInputs = Array.from(document.querySelectorAll('[data-brand-filter="true"]'));
    const cards = Array.from(grid.querySelectorAll('[data-watch-card="true"]'));

    const updateUrl = () => {
        const params = new URLSearchParams();
        const searchValue = searchInput.value.trim();

        if (searchValue) {
            params.set('q', searchValue);
        }

        if (sortSelect.value && sortSelect.value !== 'Featured') {
            params.set('sort', sortSelect.value);
        }

        brandInputs
            .filter(input => input.checked)
            .forEach(input => params.append('brand', input.value));

        const query = params.toString();
        const url = `${window.location.pathname}${query ? `?${query}` : ''}`;
        window.history.replaceState({}, '', url);
    };

    const applyFilters = (syncUrl) => {
        const searchValue = searchInput.value.trim().toLowerCase();
        const selectedBrands = new Set(
            brandInputs
                .filter(input => input.checked)
                .map(input => input.value.toLowerCase())
        );
        const sortValue = sortSelect.value || 'Featured';

        const visibleCards = cards.filter(card => {
            const name = (card.dataset.name || '').toLowerCase();
            const brand = (card.dataset.brand || '').toLowerCase();
            const description = (card.dataset.description || '').toLowerCase();

            const matchesSearch = !searchValue || name.includes(searchValue) || brand.includes(searchValue) || description.includes(searchValue);
            const matchesBrand = selectedBrands.size === 0 || selectedBrands.has(brand);

            return matchesSearch && matchesBrand;
        });

        visibleCards.sort((leftCard, rightCard) => {
            const leftPrice = Number(leftCard.dataset.price || '0');
            const rightPrice = Number(rightCard.dataset.price || '0');
            const leftIndex = Number(leftCard.dataset.index || '0');
            const rightIndex = Number(rightCard.dataset.index || '0');

            if (sortValue === 'PriceAsc') {
                return leftPrice - rightPrice || leftIndex - rightIndex;
            }

            if (sortValue === 'PriceDesc') {
                return rightPrice - leftPrice || leftIndex - rightIndex;
            }

            return leftIndex - rightIndex;
        });

        cards.forEach(card => {
            card.hidden = true;
        });

        visibleCards.forEach(card => {
            card.hidden = false;
            grid.appendChild(card);
        });

        if (countNode) {
            countNode.textContent = `Showing ${visibleCards.length} watches`;
        }

        if (emptyState) {
            emptyState.hidden = visibleCards.length > 0;
        }

        if (syncUrl) {
            updateUrl();
        }
    };

    searchInput.addEventListener('input', () => applyFilters(true));
    sortSelect.addEventListener('change', () => applyFilters(true));
    brandInputs.forEach(input => input.addEventListener('change', () => applyFilters(true)));

    if (resetButton) {
        resetButton.addEventListener('click', () => {
            searchInput.value = '';
            sortSelect.value = 'Featured';
            brandInputs.forEach(input => {
                input.checked = false;
            });
            applyFilters(true);
            searchInput.focus();
        });
    }

    applyFilters(false);
})();

function showNewsletterMessage(event) {
    event.preventDefault();

    const message = document.getElementById('newsletterMessage');
    const input = document.querySelector('.newsletter-lux-input');

    if (!message || !input) {
        return false;
    }

    if (input.value.trim() === '') {
        return false;
    }

    message.classList.add('show');
    input.value = '';

    setTimeout(() => {
        message.classList.remove('show');
    }, 2500);

    return false;
}

</script>

@code {
    public List<BrandItem> Brands { get; set; } = new();
    public List<WatchItem> Watches { get; set; } = new();
    public bool IsLoading { get; set; } = true;

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "q")]
    public string? SearchQuery { get; set; }

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "sort")]
    public string? CurrentSort { get; set; }

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery(Name = "brand")]
    public string[]? SelectedBrandNames { get; set; }

    public HashSet<string> SelectedBrands { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var watchesTask = FirestoreService.GetWatchesAsync();
            var brandsTask = FirestoreService.GetBrandsAsync();
            await Task.WhenAll(watchesTask, brandsTask);
            Watches = watchesTask.Result;
            Brands = brandsTask.Result.OrderBy(b => b.Name).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load data from Firestore: {ex.Message}");
            Watches = new();
            Brands = new();
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override void OnParametersSet()
    {
        SearchQuery = SearchQuery?.Trim() ?? string.Empty;
        CurrentSort = string.IsNullOrWhiteSpace(CurrentSort) ? "Featured" : CurrentSort;
        SelectedBrands = SelectedBrandNames is null
            ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            : SelectedBrandNames.Where(brand => !string.IsNullOrWhiteSpace(brand))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    public IEnumerable<WatchItem> FilteredWatches
    {
        get
        {
            var query = Watches.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchQuery))
            {
                var lowerSearch = SearchQuery.ToLowerInvariant();
                query = query.Where(w =>
                    w.Name.ToLowerInvariant().Contains(lowerSearch) ||
                    w.Brand.ToLowerInvariant().Contains(lowerSearch) ||
                    w.Description.ToLowerInvariant().Contains(lowerSearch)
                );
            }

            if (SelectedBrands.Any())
            {
                query = query.Where(w => SelectedBrands.Contains(w.Brand));
            }

            return CurrentSort switch
            {
                "PriceAsc" => query.OrderBy(w => w.Price),
                "PriceDesc" => query.OrderByDescending(w => w.Price),
                _ => query
            };
        }
    }

}
