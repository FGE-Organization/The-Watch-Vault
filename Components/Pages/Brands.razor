@page "/brands"

<PageTitle>Brands</PageTitle>

<section class="brands-hero">
    <div class="brands-hero-backdrop"></div>
    <div class="brands-hero-content">
        <p class="brands-tagline">House Directory</p>
        <h1 class="brands-title">Explore Our Featured Brands</h1>
        <p class="brands-subtitle">
            Discover iconic maisons and modern innovators curated for collectors and first-time enthusiasts alike.
        </p>
    </div>
</section>

<section class="brands-main">
    <div class="brands-grid">
        @foreach (var brand in BrandCards)
        {
            <article class="brand-card" style="--brand-accent:@brand.Accent">
                <div class="brand-logo" aria-hidden="true">
                    <span>@brand.Initials</span>
                </div>
                <h2 class="brand-name">@brand.Name</h2>
                <p class="brand-description">@brand.Description</p>
            </article>
        }
    </div>
</section>

