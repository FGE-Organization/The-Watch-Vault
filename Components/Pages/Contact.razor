@page "/contact"
@attribute [Microsoft.AspNetCore.Components.ExcludeFromInteractiveRouting]

<PageTitle>Contact Us — The Watch Vault</PageTitle>

<section class="contact-hero">
    <div class="contact-hero-backdrop"></div>
    <div class="contact-hero-content">
        <p class="contact-tagline">Get In Touch</p>
        <h1 class="contact-title">Contact Us</h1>
        <p class="contact-subtitle">
            We would be pleased to hear from you. Whether you have a question about our collection,
            your order, or a general inquiry, our team is here to assist you.
        </p>
    </div>
</section>

<section class="contact-main">
    <div class="contact-container">
        <div class="contact-grid">

            <div class="contact-info-card">
                <p class="contact-info-kicker">The Watch Vault</p>
                <h2 class="contact-info-title">A Refined Way to Reach Us</h2>
                <p class="contact-info-text">
                    Please complete the form and share your message with us. We value every inquiry
                    and aim to provide a thoughtful and timely response.
                </p>

                <div class="contact-feature-list">
                    <div class="contact-feature-item">
                        <span class="contact-feature-dot"></span>
                        <div>
                            <h4>Customer Assistance</h4>
                            <p>Questions about products, orders, or availability.</p>
                        </div>
                    </div>

                    <div class="contact-feature-item">
                        <span class="contact-feature-dot"></span>
                        <div>
                            <h4>General Inquiries</h4>
                            <p>Reach out for any information about The Watch Vault.</p>
                        </div>
                    </div>

                    <div class="contact-feature-item">
                        <span class="contact-feature-dot"></span>
                        <div>
                            <h4>Luxury Experience</h4>
                            <p>A premium and elegant way to connect with our brand.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contact-form-card">
                <div class="contact-form-inner">
                    <p class="contact-form-kicker">Send a Message</p>
                    <h2 class="contact-form-title">We Are Here to Help</h2>

                    <form id="contactForm" class="contact-form" onsubmit="return handleContactSubmit(event)">
                        <div class="contact-form-row">
                            <div class="contact-field">
                                <label for="fullName">Full Name</label>
                                <input id="fullName" name="fullName" type="text" placeholder="Enter your full name" required />
                            </div>

                            <div class="contact-field">
                                <label for="email">Email Address</label>
                                <input id="email" name="email" type="email" placeholder="Enter your email address" required />
                            </div>
                        </div>

                        <div class="contact-field">
                            <label for="subject">Subject</label>
                            <input id="subject" name="subject" type="text" placeholder="Enter the subject" required />
                        </div>

                        <div class="contact-field">
                            <label for="message">Message</label>
                            <textarea id="message" name="message" rows="6" placeholder="Write your message here..." required></textarea>
                        </div>

                        <div class="contact-form-actions">
                            <button type="submit" class="contact-submit-btn">Send Message</button>
                        </div>

                        <p id="contactSuccessMessage" class="contact-success-message">
                            Your message has been sent successfully.
                        </p>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

<footer class="site-footer" id="site-footer">
    <div class="footer-content">
        <div class="footer-brand">
            <h4>The Watch Vault</h4>
            <p>Your destination for luxury timepieces.</p>
        </div>
        <div class="footer-links">
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
            <a href="/login">Login</a>
            <a href="/signup">Create Account</a>
            <a href="/contact">Contact</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 The Watch Vault. All rights reserved.</p>
    </div>
</footer>

<script>
    function handleContactSubmit(event) {
        event.preventDefault();

        const form = document.getElementById("contactForm");
        const successMessage = document.getElementById("contactSuccessMessage");

        if (!form || !successMessage) {
            return false;
        }

        if (!form.checkValidity()) {
            form.reportValidity();
            return false;
        }

        successMessage.classList.add("show");
        form.reset();

        setTimeout(() => {
            successMessage.classList.remove("show");
        }, 3000);

        return false;
    }
</script>